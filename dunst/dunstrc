[global]
# Frame and separator colors
font = "Cantarell Regular 13"
frame_color = "#4e5562"  # Darker frame for a sleeker look
separator_color = frame

# Define padding and corner radius for a softer appearance
padding = 12
horizontal_padding = 12
corner_radius = 8

# Optional: Adjust transparency for modern aesthetics
transparency = 5

[urgency_low]
background = "#2a303c"  # Dark background for low urgency
foreground = "#c6d0f5"  # Light text for contrast

[urgency_normal]
background = "#2a303c"  # Consistent dark background for normal urgency
foreground = "#c6d0f5"  # Light text for readability

[urgency_critical]
background = "#4e5562"  # Different background for critical notifications
foreground = "#f8f8f2"  # Brighter text for better visibility
frame_color = "#ef9f76"  # Retaining the orange frame for critical notifications
